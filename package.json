{
  "name": "luminaweb",
  "version": "0.1.2",
  "type": "module",
  "description": "An agent-native runtime for full-stack TypeScript apps. Ship the thing. Skip the plumbing.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "start": "bun run --filter @luminaweb/edge start",
    "lint": "echo 'lint TBD'",
    "test": "echo 'test TBD'",
    "zapdev": "bun run packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/node": "^22.10.0",
    "bun-types": "1.3.14",
    "preact": "^10.24.3",
    "shadcn": "^4.10.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  },
  "dependencies": {
    "better-auth": "^1.6.14",
    "kysely": "0.28.2"
  },
  "overrides": {
    "kysely": "0.28.2"
  }
}
